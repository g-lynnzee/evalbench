{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server",
      "type": "debugpy",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/evalbench:${workspaceFolder}/evalbench/evalproto"
      },
      "args": [
        "--localhost",
      ],
      "request": "launch",
      "program": "${workspaceFolder}/evalbench/eval_server.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Client",
      "type": "debugpy",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/evalbench:${workspaceFolder}/evalbench/evalproto"
      },
      "request": "launch",
      "program": "${workspaceFolder}/evalbench/client/eval_client.py",
      "args": [
        "--insecure"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Run",
      "type": "debugpy",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/evalbench:${workspaceFolder}/evalbench/evalproto"
      },
      "request": "launch",
      "program": "${workspaceFolder}/evalbench/evalbench.py",
      "args": [
        "--experiment_config",
        "${workspaceFolder}/datasets/bat-interact/example_run_config.yaml"
      ],
      "console": "integratedTerminal"
    }
  ]
}